! APR1 simulation

&base
ymd = 2025,7,29               ! year, month, day
UTsec0 = 84292.0              ! start time in UT seconds
tdur = 14400.0                  ! duration of simulation in seconds
dtout = 3600.0                  ! how often to do file output
activ = 156.1,138,4 	 ! f107a,f107,Ap
tcfl = 0.9                    ! target cfl number
Teinf = 1500.0                ! exospheric electron temperature
/

&flags
potsolve = 0        ! solve electrodynamics:   0 - no; 1 - electrostatic; 2 - inductive
flagperiodic = 0    ! whether periodic
flagoutput = 1      ! 1 - full output
/

&setup
dtheta=19.5
dphi=42
lp=256
lq=448
lphi=256
altmin=80e3
glat=38.5
glon=196.5
gridflag=1
!flagsource=1
!iscurv=true
!nmf = 5e11
!nme = 2e11

eq_dir = '~/simulations/raid2/simulations_kamchatka/kamchatka_eq/'
/

&files
file_format='h5'
indat_size = 'inputs/simsize.h5'
indat_grid = 'inputs/simgrid.h5'
indat_file = 'inputs/initial_conditions.h5'
/

&Jpar
flagJpar=.false.     !parallel currents perhaps not meangingful in ESF simulation?
/

&gravdrift
flaggravdrift=.false.
/

&EIA
flagEIA = .true.              ! toggles EIA calculation
v0equator = 15.0              ! equatorial peak drift value
/

! (optional - default off) allow neutral background atmosphere to change during simulation
&neutral_BG
flagneuBG = .true.	 ! on or off
dtneuBG = 600.0         ! how often to call MSIS and HWM (if applicable)
msis_version = 0         ! 0 or 20; which MSIS version to use, MSIS00 or MSIS 2.0
/

! (optional - default off) whether or not to do milestone outputs; only works with h5 file output
&milestone
mcadence=1                   ! number of outputs per milestone
/

! whether or not to compute magnetic pole location based on year (.false.=use default; .true.=compute based on year)
&magpole
flagmagpole=.true.
/

! (optional - default off) Include neutral atmospheric perturbation inputs from another model/dataset
&neutral_perturb
flagdneu = 1                       ! on/off for neutral perturbations:  0 - off; 1 - on
interptype = 4                     ! how to treat the input neutral data:  1 - axisymmetric; 2 - Cartesian; 3 - 3D Cartesian
sourcemlat = 29.2664             ! magnetic latitude of the source location
sourcemlon = 259.8047            ! magnetic longitude of the source location
dtneu = 120.0                        ! time step between neutral file inputs
drhon = 16000                        ! neutral grid step size in the radial or y-direction (meridional)
dzn = 4000                          ! neutral grid step, vertical
dxn = 16000                          ! (only required if 3D) neutral grid step in x-direction (zonal)
source_dir = 'inputs/neutrals'
/
