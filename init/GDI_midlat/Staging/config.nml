! this is a gradient drift instability simulation

&base
ymd = 2020,1,2               ! year, month, day
UTsec0 = 18000.0              ! start time in UT seconds
tdur = 600.0                  ! duration of simulation in seconds
dtout = 60.0                  ! how often to do file output
activ = 150.0,150.0,50.0      ! f107a,f107,Ap
tcfl = 0.9                    ! target cfl number
Teinf = 1500.0                ! exospheric electron temperature
/

&setup
dtheta=9.75
dphi=15
lp=192
lq=256
lphi=32
altmin=80e3
glat=34.0
glon=254.0
gridflag=0
flagsource=1
grid_openparm=10.0

eq_dir = '~/simulations/ssd_ext/sims_GDI_midlat/GDI_midlat_eq'	! point to equilibrium simulation

!setup_functions = 'perturb_GDI_planar', 'gemini3d.efield.Efield_BCs'
setup_functions = 'perturb_GDI_planar'
/

&flags
potsolve = 0      ! solve electrodynamics:   0 - no; 1 - electrostatic; 2 - inductive
flagperiodic = 1
flagoutput = 1
/

&files
indat_size = 'inputs/simsize.h5'
indat_grid = 'inputs/simgrid.h5'
indat_file = 'inputs/initial_conditions.h5'
/

!&efield
!dtE0 = 30.0
!E0_dir = 'inputs/Efield/'
!/

!&Jpar
!flagJpar=.false.
!/

&precip_BG
PhiWBG=1e-6    ! total energy flux, mW/m2
W0BG=1e3       ! characteristic energy
! PhiWBG=0.05    !good for illustrating effects of precip -> damping
! PhiWBG=1e-3
/

&capacitance
flagcap=0       !use inertial capacitance? 0 - set all to zero, 1 - use ionosphere to compute, 2 - add a magnetospheric part
magcap=0.0
! magcap=5.0    !good for showing damping due to magnetosphere...
/

&milestone
mcadence=4
/
